{
  "name": "feishu-cursor-bridge",
  "version": "2.4.6",
  "description": "Feishu Cursor Bridge - 飞书 × Cursor 远程协作桌面应用",
  "keywords": [
    "mcp",
    "lark",
    "feishu",
    "cursor",
    "electron",
    "desktop"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "main": "./out/main/index.js",
  "bin": {
    "lark-bridge-mcp": "dist/index.js",
    "lark-bridge-daemon": "dist/daemon-entry.js"
  },
  "scripts": {
    "build:mcp": "tsc",
    "build:bundle": "node scripts/bundle-daemon.cjs",
    "dev:mcp": "tsx src/index.ts",
    "dev": "electron-vite dev",
    "build": "npm run build:mcp && npm run build:bundle && electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cron-parser": "^5.5.0",
    "electron-store": "^11.0.2",
    "lucide-react": "^0.577.0",
    "node-cron": "^4.2.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "esbuild": "^0.27.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
